{
  "name": "daybook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Daybook — console de pilotage quotidien (mono-utilisateur, privé).",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @daybook/server dev",
    "dev:client": "pnpm --filter @daybook/client dev",
    "build": "pnpm --filter @daybook/client build && pnpm --filter @daybook/server build",
    "typecheck": "pnpm --filter @daybook/client typecheck && pnpm --filter @daybook/server typecheck",
    "start": "node server/dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "volta": {
    "node": "22.23.1"
  }
}
